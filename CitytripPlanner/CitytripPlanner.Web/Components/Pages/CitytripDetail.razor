@page "/citytrips/{Id:int}"
@using CitytripPlanner.Features.Citytrips.GetCitytripDetail
@using CitytripPlanner.Web.Components.Citytrips
@using MediatR
@inject IMediator Mediator
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>@(_trip?.Title ?? "Citytrip")</PageTitle>

@if (_loading)
{
    <div class="loading-state">
        <div class="spinner"></div>
        <p>Loading citytrip…</p>
    </div>
}
else if (_trip is null)
{
    <div class="page-header">
        <a href="/" class="btn-back-inline">← All citytrips</a>
        <h1>Not found</h1>
    </div>
    <div class="not-found">
        <p>This citytrip could not be found.</p>
    </div>
}
else
{
    <div class="detail-hero">
        <img src="@_trip.ImageUrl"
             alt="@_trip.Title"
             onerror="this.onerror=null; this.src='data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%27800%27 height=%27400%27%3E%3Crect fill=%27%23ddd%27 width=%27800%27 height=%27400%27/%3E%3Ctext fill=%27%23999%27 x=%2750%25%27 y=%2750%25%27 dominant-baseline=%27middle%27 text-anchor=%27middle%27 font-size=%2724%27%3EImage unavailable%3C/text%3E%3C/svg%3E';" />
        <div class="hero-overlay">
            <a href="/" class="btn-back">← All citytrips</a>
            <div class="hero-content">
                <h1>@_trip.Title</h1>
                <p class="hero-meta">
                    <span>📍 @_trip.Destination</span>
                    <span>📅 @_trip.StartDate.ToString("MMM d") – @_trip.EndDate.ToString("MMM d, yyyy")</span>
                    @if (_trip.MaxParticipants.HasValue)
                    {
                        <span>👥 Max @_trip.MaxParticipants participants</span>
                    }
                </p>
            </div>
        </div>
    </div>

    <div class="detail-body">
        @if (!string.IsNullOrWhiteSpace(_trip.Description))
        {
            <section class="detail-section">
                <h2>About this trip</h2>
                <p class="description">@_trip.Description</p>
            </section>
        }

        <div class="detail-layout">
            <div class="schedule-column">
                @if (_trip.DayPlans is { Count: > 0 })
                {
                    <DaySchedulePanel DayPlans="@_trip.DayPlans" OnDayVisible="HandleDayVisible" />
                }
                else
                {
                    <p class="empty-schedule">No day schedule available for this trip.</p>
                }
            </div>
            <div class="map-column">
                <TripMapSidebar Markers="@_activeMarkers" MapLoadFailed="@_mapLoadFailed" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private CitytripDetailResponse? _trip;
    private bool _loading = true;
    private bool _mapLoadFailed = false;
    private List<PlaceDetail> _activeMarkers = new();
    private DotNetObjectReference<CitytripDetail>? _dotNetRef;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _trip = await Mediator.Send(new GetCitytripDetailQuery(Id));
        if (_trip?.DayPlans is { Count: > 0 })
        {
            UpdateMarkersForDay(_trip.DayPlans[0].DayNumber);
        }
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _trip?.DayPlans is { Count: > 0 })
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("tripMap.observeDaySections", _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnDayChanged(int dayNumber)
    {
        UpdateMarkersForDay(dayNumber);
        StateHasChanged();
    }

    private void HandleDayVisible(int dayNumber)
    {
        UpdateMarkersForDay(dayNumber);
    }

    private void UpdateMarkersForDay(int dayNumber)
    {
        var day = _trip?.DayPlans?.FirstOrDefault(d => d.DayNumber == dayNumber);
        _activeMarkers = day?.Events
            .Where(e => e.Place is not null)
            .Select(e => e.Place!)
            .ToList() ?? new();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
    }
}
